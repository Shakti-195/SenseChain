# ==========================================
#   SENSECHAIN V11 - PRODUCTION READY
# ==========================================

# --- 🐍 Python & Backend ---
# Virtual Environments (NEVER push these)
**/myenv/
**/venv/
**/env/
**/ENV/

# Environment Secrets (Crucial: Vercel/Render will use their own Dashboard vars)
.env
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Python Cache & Temp Files
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/*.pyo
**/*.pyd

# --- 🧠 AI & Machine Learning ---
# Large Model Weights (Keep local or use Git LFS)
**/*.pth
**/*.bin
**/*.weights
# Exception: Keeping your specific model and data
!Backend/app/sense_assistant.pth
!Backend/app/sense_assistant_data.json

# AI Pickles & Logs
**/sense_vectorstore.pkl
Backend/dataset_generator.py
Backend/train_assistant.py

# --- ⛓️ Blockchain Data ---
# Local Ledger Storage (Let the DB handle this in production)
**/blockchain_data.json

# --- ⚛️ Frontend (React/Vite) ---
# Node Modules (Heavy - MUST IGNORE)
**/node_modules/

# Build & Production Files (Vercel will build its own 'dist')
Frontend/dist/
Frontend/build/
dist/
build/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# --- 📄 Reports & Logs ---
**/sensechain_report.pdf
**/audit.csv
**/*.log
**/*.tmp

# --- 🖥️ System & Editor ---
.vscode/
.idea/
.DS_Store
*.swp
Thumbs.db
desktop.ini

# ==========================================
#   EXCEPTIONS (Files we WANT to keep)
# ==========================================
!start_sensechain.bat
!requirements.txt
!Frontend/package.json
!Frontend/vite.config.js