# ==========================================
#   SENSECHAIN V11 - OPTIMIZED REPOSITORY
# ==========================================

# --- 🐍 Python & Backend ---
# Virtual Environments (NEVER push these)
**/myenv/
**/venv/
**/env/
**/ENV/

# Environment Secrets
.env
Backend/.env
Frontend/.env
Frontend/.env.local

# Python Cache & Temp Files
**/__pycache__/
**/*.py[cod]
**/*$py.class
**/*.pyo
**/*.pyd

# --- 🧠 AI & Machine Learning ---
# Large Model Weights (Keep local or use Git LFS)
# Ab models app/ folder ke andar ho sakte hain
**/*.pth
**/*.bin
**/*.weights
**/sense_assistant.pth

# Datasets & Training Scripts (Optional: Agar aap dataset hide rakhna chahte hain)
**/sense_assistant_data.json
**/sense_vectorstore.pkl
Backend/dataset_generator.py
Backend/train_assistant.py

# --- ⛓️ Blockchain Data ---
# Local Ledger Storage (Ye har mine par badalta hai, isse push mat karo)
**/blockchain_data.json

# --- ⚛️ Frontend (React/Vite) ---
# Node Modules (Very heavy - MUST IGNORE)
**/node_modules/

# Build & Production Files
Frontend/dist/
Frontend/build/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# --- 📄 Reports & Logs ---
# Forensic reports (Local generated files)
**/sensechain_report.pdf
**/audit.csv
**/*.log
**/*.tmp

# --- 🖥️ System & Editor ---
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# ==========================================
#   EXCEPTIONS (Files we WANT to keep)
# ==========================================
# Hum start script aur requirements push karna chahte hain
!start_sensechain.bat
!requirements.txt